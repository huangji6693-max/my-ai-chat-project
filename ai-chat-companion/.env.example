# ═══════════════════════════════════════════════════════════
# 撩咖后端配置模板 — 复制为 .env 并填入真实值
# ═══════════════════════════════════════════════════════════

# Anthropic Claude API
# 去 https://console.anthropic.com/ 申请
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_MAX_TOKENS=512

# History
# 发送给 Claude 的历史消息条数上限 (越大上下文越长, 成本越高)
HISTORY_LIMIT=30

# 数据库
# 默认 SQLite, 生产建议 PostgreSQL
DATABASE_URL=sqlite:///./chat.db
# DATABASE_URL=postgresql://user:pass@host:5432/liaoka

# CORS 白名单 (逗号分隔)
# 生产环境必须改成你自己的域名, 不要用 *
CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,http://localhost:5173

# Rate limit (每分钟每 IP)
RATE_LIMIT_CHAT=20/minute

# 运行环境
# development: 异常详情会返回到前端便于调试
# production: 异常详情脱敏, 只返回通用错误
ENVIRONMENT=development
